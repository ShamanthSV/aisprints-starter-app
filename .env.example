# QuizMaker Sprint 1 — environment template (auth contract)
# Single source of truth: docs/sprint-1/prd-auth-contract-env.mdc
#
# OpenNext + Cloudflare: copy secrets into `.dev.vars` at the repo root (gitignored).
# Next.js may also load `.env.local` for some keys; never commit real secrets.

# Optional — matches Cloudflare.Env / local tooling
NEXTJS_ENV=development

# Required when issuing or verifying JWTs (HS256). Use a long random string.
AUTH_JWT_SECRET=Shamanth@12345678

# D1 binding `quizmaker_app_database` is declared in wrangler.jsonc — not a process.env key here.
