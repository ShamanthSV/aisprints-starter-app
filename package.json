{
	"name": "aisprints-starter-app",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"deploy:cf": "npm run d1:migrate:remote && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"d1:provision": "node scripts/d1-provision.mjs",
		"d1:create": "wrangler d1 create quizmaker-app-database",
		"d1:list": "wrangler d1 list --json",
		"d1:migrate:local": "wrangler d1 migrations apply quizmaker-app-database --local",
		"d1:migrate:remote": "wrangler d1 migrations apply quizmaker-app-database --remote",
		"test": "vitest",
		"test:ci": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:install": "playwright install --with-deps"
	},
	"dependencies": {
		"@hookform/resolvers": "^3.10.0",
		"@opennextjs/cloudflare": "^1.11.0",
		"@radix-ui/react-label": "^2.1.2",
		"@radix-ui/react-slot": "^1.1.2",
		"bcryptjs": "^2.4.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"jose": "^6.0.10",
		"next": "15.5.6",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-hook-form": "^7.55.0",
		"tailwind-merge": "^2.6.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250321.0",
		"@eslint/eslintrc": "^3",
		"@playwright/test": "^1.51.0",
		"@tailwindcss/postcss": "^4",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.2.0",
		"@testing-library/user-event": "^14.5.2",
		"@types/bcryptjs": "^3.0.0",
		"@types/node": "^20.19.25",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^4.3.4",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"jsdom": "^26.0.0",
		"tailwindcss": "^4",
		"typescript": "^5",
		"vite": "^6.0.0",
		"vitest": "^3.0.0",
		"wrangler": "^4.51.0"
	}
}
