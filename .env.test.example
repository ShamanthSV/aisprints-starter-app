# Copy to `.env.test` for local tooling that reads dotenv (optional).
# Playwright reads the **process environment** — export vars in your shell, or set them in CI.
#
# Placeholder values only; never commit real secrets.

# Base URL for UI navigation (`playwright.config.ts` default: http://127.0.0.1:3000)
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Same-origin E2E: Playwright `request` uses `playwright.config.ts` baseURL + relative `/api/...`
# (Phase C — `docs/sprint-1/prd-auth-e2e.mdc`). Only set a separate API origin if the app used a
# different absolute API base (not the case in Sprint 1).
# E2E_API_URL=http://127.0.0.1:3000

# Skip auto-starting `npm run dev` when the server is already up
# PLAYWRIGHT_SKIP_WEBSERVER=1
